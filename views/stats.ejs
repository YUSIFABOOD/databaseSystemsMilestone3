<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Statistics - Data Catalog</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="/theme.js"></script>
    <style>
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }
        @media (max-width: 900px) {
            .stats-grid { grid-template-columns: 1fr; }
        }
        .chart-box {
            background-color: var(--md-sys-color-surface-variant);
            border-radius: 12px;
            padding: 16px;
            margin-top: 16px;
            max-height: 280px;
            overflow-y: auto;
        }
        /* Custom scrollbar for better UI */
        .chart-box::-webkit-scrollbar {
            width: 8px;
        }
        .chart-box::-webkit-scrollbar-track {
            background: transparent;
        }
        .chart-box::-webkit-scrollbar-thumb {
            background-color: rgba(0,0,0,0.2);
            border-radius: 4px;
        }
        @media (prefers-color-scheme: dark) {
            .chart-box::-webkit-scrollbar-thumb {
                background-color: rgba(255,255,255,0.2);
            }
        }
        .bar-container {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
        }
        .bar-label {
            width: 150px;
            font-size: 12px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            padding-right: 8px;
        }
        .bar-track {
            flex: 1;
            display: flex;
            align-items: center;
        }
        .bar {
            background-color: var(--md-sys-color-primary);
            height: 20px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 8px;
            color: white;
            font-size: 11px;
            min-width: 30px;
            transition: width 0.5s ease-out;
        }
        .tag-pill {
            display: inline-block;
            background-color: var(--md-sys-color-secondary-container);
            color: var(--md-sys-color-on-secondary-container);
            padding: 4px 12px;
            border-radius: 16px;
            font-size: 12px;
            margin: 4px;
            font-weight: 500;
            box-shadow: var(--elevation-1);
        }
    </style>
</head>
<body>
    <header>
        <h1>Data Catalog System</h1>
        <nav>
            <a href="/">Home</a>
            <a href="/datasets">Datasets</a>
            <strong style="padding:8px 16px;">Statistics</strong>
            <button class="theme-toggle" onclick="toggleTheme()">🌗</button>
        </nav>
    </header>
    <main>
        <div class="card">
            <h2>Platform Statistics</h2>
            <p>Various analytics over the public dataset collection and our users' logging activities.</p>
        </div>

        <div class="stats-grid">
            <div class="card">
                <h3>Top 5 Contributing Organizations</h3>
                <div class="chart-box">
                    <% if(topOrgs.length > 0) { %>
                    <% topOrgs.forEach(o => { 
                        let max = topOrgs[0].count;
                        let w = Math.max(0, (o.count / max) * 100);
                    %>
                    <div class="bar-container" title="<%= o.orgTitle || o.orgName %>">
                        <div class="bar-label"><%= o.orgTitle || o.orgName %></div>
                        <div class="bar-track">
                            <div class="bar" style="width: <%= w %>%"><%= o.count %></div>
                        </div>
                    </div>
                    <% }) %>
                    <% } else { %> <p>No data</p> <% } %>
                </div>
            </div>

            <div class="card">
                <h3>Top 5 Datasets by User Count</h3>
                <div class="chart-box">
                    <% if(topDatasets.length > 0) { %>
                    <% topDatasets.forEach(d => { 
                        let max = topDatasets[0].count;
                        let w = Math.max(0, (d.count / max) * 100);
                    %>
                    <div class="bar-container" title="<%= d.name %>">
                        <div class="bar-label"><%= d.name %></div>
                        <div class="bar-track">
                            <div class="bar" style="width: <%= w %>%"><%= d.count %></div>
                        </div>
                    </div>
                    <% }) %>
                    <% } else { %> <p>No user projects logged yet.</p> <% } %>
                </div>
            </div>

            <div class="card">
                <h3>Dataset Counts by Organization</h3>
                <div class="chart-box">
                    <% if(byOrg.length > 0) { %>
                    <% byOrg.forEach(o => { 
                        let max = byOrg[0].count;
                        let w = Math.max(0, (o.count / max) * 100);
                    %>
                    <div class="bar-container" title="<%= o.orgTitle || o.orgName %>">
                        <div class="bar-label"><%= o.orgTitle || o.orgName %></div>
                        <div class="bar-track">
                            <div class="bar" style="width: <%= w %>%"><%= o.count %></div>
                        </div>
                    </div>
                    <% }) %>
                    <% } else { %> <p>No data</p> <% } %>
                </div>
            </div>

            <div class="card">
                <h3>Dataset Counts by Topic</h3>
                <div class="chart-box">
                    <% if(byTopic.length > 0) { %>
                    <% byTopic.forEach(t => { 
                        let max = byTopic[0].count;
                        let w = Math.max(0, (t.count / max) * 100);
                    %>
                    <div class="bar-container" title="<%= t.topicName %>">
                        <div class="bar-label" style="text-transform: capitalize;"><%= t.topicName %></div>
                        <div class="bar-track">
                            <div class="bar" style="width: <%= w %>%"><%= t.count %></div>
                        </div>
                    </div>
                    <% }) %>
                    <% } else { %> <p>No data</p> <% } %>
                </div>
            </div>

            <div class="card">
                <h3>Dataset Counts by Format</h3>
                <div class="chart-box">
                    <% if(byFormat.length > 0) { %>
                    <% byFormat.forEach(f => { 
                        let max = byFormat[0].count;
                        let w = Math.max(0, (f.count / max) * 100);
                    %>
                    <div class="bar-container" title="<%= f.format %>">
                        <div class="bar-label"><%= f.format %></div>
                        <div class="bar-track">
                            <div class="bar" style="width: <%= w %>%"><%= f.count %></div>
                        </div>
                    </div>
                    <% }) %>
                    <% } else { %> <p>No data</p> <% } %>
                </div>
            </div>

            <div class="card">
                <h3>Dataset Counts by Type</h3>
                <div class="chart-box">
                    <% if(byType.length > 0) { %>
                    <% byType.forEach(t => { 
                        let max = Math.max(...byType.map(x=>x.count));
                        let w = Math.max(0, (t.count / max) * 100);
                    %>
                    <div class="bar-container" title="<%= t.type %>">
                        <div class="bar-label" style="text-transform: capitalize;"><%= t.type %></div>
                        <div class="bar-track">
                            <div class="bar" style="width: <%= w %>%"><%= t.count %></div>
                        </div>
                    </div>
                    <% }) %>
                    <% } else { %> <p>No data</p> <% } %>
                </div>
            </div>

            <div class="card">
                <h3>Usage By Project Type</h3>
                <div class="chart-box">
                    <% if(usageByProject.length > 0) { %>
                    <% usageByProject.forEach(u => { 
                        let max = Math.max(...usageByProject.map(x=>x.count));
                        let w = Math.max(0, (u.count / max) * 100);
                    %>
                    <div class="bar-container">
                        <div class="bar-label" style="text-transform: capitalize;"><%= u.category %></div>
                        <div class="bar-track">
                            <div class="bar" style="width: <%= w %>%"><%= u.count %></div>
                        </div>
                    </div>
                    <% }) %>
                    <% } else { %> <p>No user projects logged yet.</p> <% } %>
                </div>
                
                <h4 style="margin-top: 24px;">Top 10 Tags Per Category</h4>
                <div class="chart-box" style="margin-top: 8px;">
                    <% Object.keys(topTags).forEach(cat => { %>
                        <h5 style="text-transform: capitalize; margin-bottom:8px; margin-top:8px; color: var(--md-sys-color-primary);"><%= cat %></h5>
                        <div style="margin-bottom: 12px;">
                        <% topTags[cat].forEach(t => { %>
                            <span class="tag-pill"><%= t.tag %> (<%= t.count %>)</span>
                        <% }) %>
                        </div>
                    <% }) %>
                    <% if(Object.keys(topTags).length === 0) { %> <p>No tags usage logged yet.</p> <% } %>
                </div>
            </div>
        </div>
    </main>
</body>
</html>