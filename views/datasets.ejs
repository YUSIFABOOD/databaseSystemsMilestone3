<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Datasets</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="/theme.js"></script>
</head>
<body>
    <header>
        <h1>Data Catalog System</h1>
        <nav>
            <a href="/">Home</a>
            <strong style="padding:8px 16px;">Datasets</strong>
            <a href="/stats">Statistics</a>
            <button class="theme-toggle" onclick="toggleTheme()">🌗</button>
        </nav>
    </header>
    <main>
        <div class="card">
            <h2>Browse Datasets</h2>
            <form method="GET" action="/datasets" class="filters-bar">
                <div class="input-group">
                    <label>Organization Type</label>
                    <select name="orgType">
                        <option value="">All</option>
                        <% orgTypes.forEach(t => { %>
                            <option value="<%= t %>" <%= filters.orgType === t ? 'selected' : '' %>><%= t %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="input-group">
                    <label>Format</label>
                    <select name="format">
                        <option value="">All</option>
                        <% formats.forEach(f => { %>
                            <option value="<%= f %>" <%= filters.format === f ? 'selected' : '' %>><%= f %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="input-group">
                    <label>Tag</label>
                    <input type="text" name="tag" value="<%= filters.tag || '' %>" placeholder="e.g. health">
                </div>
                <button type="submit">Apply Filters</button>
            </form>
        </div>

        <div class="card" style="padding:0">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Target Dataset Name</th>
                            <th>Format</th>
                            <th>Org Title</th>
                            <th>Org Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% datasets.forEach(d => { %>
                            <tr>
                                <td style="font-weight: 500;">
                                    <a href="/datasets/<%= d.id %>" style="color: var(--md-sys-color-primary); text-decoration: none;"><%= d.name %></a>
                                </td>
                                <td><%= d.format || 'N/A' %></td>
                                <td>
                                    <% if (d.orgName) { %>
                                        <a href="/organization/<%= d.orgName %>" style="color: inherit; text-decoration: none;">
                                            <%= d.orgTitle || d.orgName %>
                                        </a>
                                    <% } else { %>
                                        N/A
                                    <% } %>
                                </td>
                                <td><%= d.orgType || 'N/A' %></td>
                            </tr>
                        <% }) %>
                        <% if(datasets.length === 0) { %>
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 32px; color: var(--md-sys-color-on-surface-variant);">No datasets matched your filters. Try clearing them!</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            
            <% if (pagination && pagination.totalPages > 1) { %>
                <div class="pagination" style="padding: 24px; display:flex; align-items:center; gap:16px;">
                    <% if (pagination.page > 1) { %>
                        <a href="/datasets?page=<%= pagination.page - 1 %>&orgType=<%= filters.orgType || '' %>&format=<%= filters.format || '' %>&tag=<%= filters.tag || '' %>">Previous</a>
                    <% } %>
                    
                    <form method="GET" action="/datasets" style="display:flex; align-items:center; gap:8px; margin:0;">
                        <input type="hidden" name="orgType" value="<%= filters.orgType || '' %>">
                        <input type="hidden" name="format" value="<%= filters.format || '' %>">
                        <input type="hidden" name="tag" value="<%= filters.tag || '' %>">
                        <span>Page</span>
                        <input type="number" name="page" value="<%= pagination.page %>" min="1" max="<%= pagination.totalPages %>" style="width: 70px; padding: 4px 8px; text-align:center;">
                        <span>of <%= pagination.totalPages %></span>
                        <button type="submit" style="padding: 6px 12px; margin-left: 8px;">GO</button>
                    </form>

                    <% if (pagination.page < pagination.totalPages) { %>
                        <a href="/datasets?page=<%= pagination.page + 1 %>&orgType=<%= filters.orgType || '' %>&format=<%= filters.format || '' %>&tag=<%= filters.tag || '' %>">Next</a>
                    <% } %>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>